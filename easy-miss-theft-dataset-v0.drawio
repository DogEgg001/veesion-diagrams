          <mxGeometry height="100" width="400" x="80" y="550" as="geometry" />
        </mxCell>
        <mxCell id="m3b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;" value="&lt;b&gt;Non-detected branch&lt;/b&gt;&lt;br&gt;No proba history → all entries are missed by definition (client-reported)&lt;br&gt;Apply easy filter (agreement ≥ K)&lt;br&gt;&lt;b&gt;⇒ easy-miss set (no recall computable)&lt;/b&gt;" vertex="1">
